# Local bind address for the Node server.
HOST=127.0.0.1
PORT=4317

# External origin used when generating open links.
# Local development example: http://127.0.0.1:4317
# Tunnel / reverse proxy example: https://term.example.com
PUBLIC_BASE_URL=http://127.0.0.1:4317

# Replace before exposing the service publicly.
SESSION_SECRET=change-me

# SQLite database location. Use :memory: for ephemeral testing only.
DATABASE_PATH=./data/term-gateway.sqlite

# Set COOKIE_SECURE=true when PUBLIC_BASE_URL uses HTTPS.
COOKIE_NAME=term_gateway_session
COOKIE_SECURE=false

# Open-link validity window in seconds. Default: 30 minutes.
OPEN_TOKEN_TTL_SECONDS=1800

# Keep external proxy/tunnel config aligned with these values:
# - ingress.hostname should match the host in PUBLIC_BASE_URL
# - ingress.service should point to http://HOST:PORT
