{
  "name": "term-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MVP read-only web terminal gateway with local file-backed session registry.",
  "scripts": {
    "dev": "node --env-file=.env --experimental-strip-types --watch src/server.ts",
    "test": "tsx --test test/*.test.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "ws": "^8.20.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
