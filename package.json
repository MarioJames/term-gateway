{
  "name": "term-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MVP read-only web terminal gateway with local file-backed session registry.",
  "scripts": {
    "dev": "node --env-file=.env --experimental-strip-types --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/server.js"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
